# Example environment file for local development and CI.
#
# Copy this file to `.env.local` and fill in your own TEST-MODE values:
#   cp .env.example .env.local
#
# Use only Stripe TEST-MODE keys here (pk_test_/sk_test_ and a test webhook secret).
# LIVE keys are configured ONLY in the Cloudflare Pages production environment's
# secret store (dashboard or `wrangler pages secret`) — never commit them and
# never embed them in client code. All Stripe values below are fake placeholders.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe (TEST MODE ONLY in local/CI)
# Publishable key is the ONLY Stripe value exposed to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Server-side only — never shipped to the client.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Shopify (optional)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_token

# Site
NEXT_PUBLIC_SITE_URL=https://amplifyannarbor.com
